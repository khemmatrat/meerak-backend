{
  "type": "module",
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t kyc-backend .",
    "docker:run": "docker run -p 3001:3001 kyc-backend",
    "migrate": "psql $DATABASE_URL -f src/database/schema-categories-fixed.sql",
    "migrate:financial": "node scripts/run-migration.js 013",
    "migrate:audit": "node scripts/run-migration.js 014",
    "auto-payout": "node scripts/auto-payout-cron.js",
    "postinstall": "echo Skipping migrate"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.11.2",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "omise": "^1.1.0",
    "pg": "^8.11.3",
    "redis": "^4.7.1",
    "sharp": "^0.33.5",
