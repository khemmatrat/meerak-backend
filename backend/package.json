    "@types/express": "^4.17.17",
    "@types/express-validator": "^3.0.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/pg": "^8.10.2",
    "@types/socket.io": "^3.0.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
